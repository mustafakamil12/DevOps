import os
import platform
import pyodbc
import pandas as pd
from pyxlsb import Workbook

def detect_environment():
    """Detect if we're running on Windows or Linux RHEL"""
    system = platform.system().lower()
    if system == 'windows':
        return 'windows'
    elif system == 'linux':
        # Additional check for RHEL if needed
        try:
            with open('/etc/redhat-release', 'r') as f:
                if 'red hat' in f.read().lower():
                    return 'rhel'
        except FileNotFoundError:
            pass
    return 'other'

def create_connection_string(env, server, database, username, password):
    """Create appropriate connection string based on environment"""
    if env == 'windows':
        return f'DRIVER={{ODBC Driver 17 for SQL Server}};SERVER={server};DATABASE={database};UID={username};PWD={password}'
    elif env == 'rhel':
        # Try Microsoft's ODBC driver first, fall back to FreeTDS
        try:
            pyodbc.connect('DRIVER={ODBC Driver 17 for SQL Server};SERVER=test;DATABASE=test;')
            return f'DRIVER={{ODBC Driver 17 for SQL Server}};SERVER={server};DATABASE={database};UID={username};PWD={password}'
        except:
            return f'DRIVER={{FreeTDS}};SERVER={server};DATABASE={database};UID={username};PWD={password};TDS_Version=8.0;Port=1433;'
    else:
        raise EnvironmentError("Unsupported operating system")

def export_to_xlsb(df, output_file):
    """Export DataFrame to XLSB format"""
    try:
        with Workbook(output_file) as wb:
            with wb.new_sheet('Sheet1') as ws:
                # Write header
                ws.append(list(df.columns))
                # Write data rows
                for _, row in df.iterrows():
                    ws.append(list(row))
        return True
    except Exception as e:
        print(f"XLSB export error: {str(e)}")
        return False

def main():
    # Configuration - adjust these values
    config = {
        'server': 'your_server',
        'database': 'your_database',
        'username': 'your_username',
        'password': 'your_password',
        'query': 'SELECT * FROM your_table',
        'output_file': 'output.xlsb'
    }

    # Detect environment
    env = detect_environment()
    print(f"Detected environment: {env.upper()}")

    if env not in ['windows', 'rhel']:
        print("Error: This script only supports Windows and RHEL Linux")
        return

    # Create connection string
    try:
        conn_str = create_connection_string(env, config['server'], config['database'], 
                                          config['username'], config['password'])
    except EnvironmentError as e:
        print(str(e))
        return

    # Connect to SQL Server and fetch data
    try:
        with pyodbc.connect(conn_str) as conn:
            print("Connected to SQL Server successfully")
            df = pd.read_sql(config['query'], conn)
            print(f"Retrieved {len(df)} rows from database")
            
            # Export to XLSB
            if export_to_xlsb(df, config['output_file']):
                print(f"Data successfully exported to {config['output_file']}")
            else:
                print("Failed to export data to XLSB format")
                
    except pyodbc.Error as e:
        print(f"Database connection error: {str(e)}")
        if env == 'rhel':
            print("\nFor RHEL, ensure you have:")
            print("1. unixODBC installed (sudo yum install unixODBC unixODBC-devel)")
            print("2. Either Microsoft's ODBC driver or FreeTDS installed")
            print("3. Proper DSN configuration in /etc/odbc.ini and /etc/odbcinst.ini")

if __name__ == "__main__":
    # Check for required packages
    try:
        import pyodbc
        import pandas
        from pyxlsb import Workbook
    except ImportError as e:
        print(f"Missing required package: {str(e)}")
        print("Install with: pip install pyodbc pandas pyxlsb")
        exit(1)
    
    main()
