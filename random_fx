import os
import io
import time
import csv
import queue
import threading
from datetime import datetime
from pydub import AudioSegment
from pydub.utils import make_chunks
import whisper
import requests
import warnings


os.environ["OMP_NUM_THREADS"] = "1"
os.environ["MKL_NUM_THREADS"] = "1"


# Silence Whisper's FP16 warning
warnings.filterwarnings("ignore", message="FP16 is not supported on CPU")

# --- Configuration ---
STREAMS = {
    "96.7 FM": "https://playerservices.streamtheworld.com/api/livestream-redirect/KTCKAMAAC.aac",
    "105.3 FM": "https://live.amperwave.net/direct/audacy-krldfmaac-imc"  # Replace with working stream URL
}
CHUNK_LENGTH_MS = 30 * 1000
AD_KEYWORDS = ["sponsored", "call now", "limited time", "offer", "buy", "sale", "promotion", "discount", "visit us", "promo code"]
LOG_FILE = "radio_ads_log.csv"

# --- Setup Whisper ---
model = whisper.load_model("base")

# --- Create log file if it doesn’t exist ---
if not os.path.exists(LOG_FILE):
    with open(LOG_FILE, "w", newline="") as f:
        writer = csv.writer(f)
        writer.writerow(["Timestamp", "Station", "Transcript"])

# --- Ad detection logic ---
def detect_ad(text):
    lower_text = text.lower()
    return any(keyword in lower_text for keyword in AD_KEYWORDS)

# --- Queue for transcription ---
audio_queue = queue.Queue()

def transcription_worker():
    while True:
        station, audio_chunk, chunk_id = audio_queue.get()
        if station is None:
            break

        filename = f"temp_{station.replace(' ', '_')}_{chunk_id}.mp3"
        audio_chunk.export(filename, format="mp3")

        try:
            result = model.transcribe(filename)
            transcript = result.get("text", "")
            if detect_ad(transcript):
                print(f"📢 Ad detected on {station}: {transcript}")
                with open(LOG_FILE, "a", newline="") as f:
                    writer = csv.writer(f)
                    writer.writerow([datetime.now().isoformat(), station, transcript])
            else:
                print(f"✅ No ad on {station} [chunk {chunk_id}]")
        except Exception as e:
            print(f"❌ Transcription error on {station} chunk {chunk_id}: {e}")
        finally:
            if os.path.exists(filename):
                os.remove(filename)
        audio_queue.task_done()

# --- Stream handling ---
def stream_and_process(station, url):
    print(f"🔊 Listening to {station}...")
    try:
        response = requests.get(url, stream=True)
        audio_data = bytes()
        chunk_id = 0

        for block in response.iter_content(1024):
            audio_data += block
            if len(audio_data) >= 500_000:
                print(f"📥 Received {len(audio_data)} bytes from {station}")
                try:
                    audio = AudioSegment.from_file(io.BytesIO(audio_data), format="aac")
                    chunks = make_chunks(audio, CHUNK_LENGTH_MS)
                    for chunk in chunks:
                        audio_queue.put((station, chunk, chunk_id))
                        chunk_id += 1
                except Exception as e:
                    print(f"⚠️ Error decoding audio for {station}: {e}")
                audio_data = bytes()

    except Exception as e:
        print(f"🔌 Error streaming {station}: {e}")

# --- Main entrypoint ---
def main():
    # Start transcription worker thread (only one)
    worker = threading.Thread(target=transcription_worker, daemon=True)
    worker.start()

    # Start stream threads
    threads = []
    for station, url in STREAMS.items():
        t = threading.Thread(target=stream_and_process, args=(station, url))
        t.start()
        threads.append(t)

    for t in threads:
        t.join()

    # Stop the transcription worker gracefully
    audio_queue.put((None, None, None))
    audio_queue.join()

if __name__ == "__main__":
    main()
