import pandas as pd
from tabulate import tabulate

def compare_csvs(file1, file2, key_column):
    df1 = pd.read_csv(file1).set_index(key_column)
    df2 = pd.read_csv(file2).set_index(key_column)

    # Align columns and rows
    df1, df2 = df1.align(df2, join='outer', axis=1)
    df1 = df1.fillna("⛔ MISSING")
    df2 = df2.fillna("⛔ MISSING")

    # Find differences
    diff_mask = df1 != df2
    diffs = df1[diff_mask].stack().reset_index()
    diffs.columns = [key_column, "Column", "File1 Value"]
    diffs["File2 Value"] = df2[diff_mask].stack().values

    print(tabulate(diffs, headers="keys", tablefmt="grid"))

# Example usage:
compare_csvs("file1.csv", "file2.csv", key_column="id")
