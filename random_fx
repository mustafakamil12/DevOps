import logging
import confluent_kafka

# Configure root logger for the app
logging.basicConfig(level=logging.INFO, format="%(asctime)s - %(levelname)s - %(message)s")

# Suppress logging for confluent_kafka
logging.getLogger("confluent_kafka").setLevel(logging.CRITICAL)
logging.getLogger("confluent_kafka.admin").setLevel(logging.CRITICAL)  # If using Kafka Admin API

# Suppress logs from underlying HTTP requests (used by confluent_kafka)
logging.getLogger("urllib3").setLevel(logging.WARNING)
logging.getLogger("requests").setLevel(logging.WARNING)
logging.getLogger("httpx").setLevel(logging.WARNING)  # If using httpx

# Ensure that no extra handlers re-enable logging
logging.getLogger("confluent_kafka").propagate = False
logging.getLogger("urllib3").propagate = False
logging.getLogger("requests").propagate = False
logging.getLogger("httpx").propagate = False

# Example logging in the app
logging.info("This is an info message from the application.")
