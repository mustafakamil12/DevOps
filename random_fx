import pandas as pd

def map_and_align_columns(source_path, column_mapping):
    """
    Reads a CSV file, maps the column names to match the destination table, 
    and returns an aligned DataFrame.

    Parameters:
        source_path (str): Path to the CSV file.
        column_mapping (dict): Dictionary mapping source column names to destination column names.

    Returns:
        pd.DataFrame: Transformed DataFrame ready for insertion into the database.
    """
    # Read the CSV file
    df = pd.read_csv(source_path)

    # Rename columns based on the mapping
    df.rename(columns=column_mapping, inplace=True)

    # Ensure the final DataFrame matches the exact order of destination table columns
    destination_columns = list(column_mapping.values())  # Extract ordered column names
    df = df[destination_columns]  # Reorder columns

    return df

# Example usage
if __name__ == "__main__":
    # Define the source CSV file path
    csv_path = "W:\\source_data.csv"

    # Define the column mapping (Source → Destination)
    column_mapping = {
        "name_1": "name",
        "age_(test)": "age",
        "class_now": "class"
    }

    # Get the transformed DataFrame
    aligned_df = map_and_align_columns(csv_path, column_mapping)

    # Print the DataFrame (or insert into database)
    print(aligned_df.head())

    # Optionally, save the transformed data to a new CSV file
    aligned_df.to_csv("W:\\aligned_data.csv", index=False)
