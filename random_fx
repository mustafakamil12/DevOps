# Define a function to clean the 'Supported Releases' column
def clean_supported_releases(text):
    if pd.isna(text):
        return None

    # Remove '+' and extra whitespace
    text = text.replace('+', '').strip()

    # Use regex to split at positions where a new ESXi version begins
    parts = re.findall(r'(ESXi\s*\d+\.\d+\s*(?:U\d+)?)', text)

    # Join the parts with ' | '
    return ' | '.join(parts)

# Apply the cleaning function to the column
df['Supported Releases'] = df['Supported Releases'].apply(clean_supported_releases)
